# Copy file ini menjadi .env dan isi nilainya

# API Key OpenRouter — dapatkan di https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model AI yang digunakan (free tier)
AI_MODEL=arcee-ai/trinity-large-preview:free

# Origins yang diizinkan (pisah koma)
ALLOWED_ORIGINS=http://localhost:5173,https://viral-clipper-ai.vercel.app

# Port server (default 3001)
PORT=3001
